# AWS credentials (in workshop, provided via instance role - no need to set manually)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
AWS_REGION=us-west-2

# Bedrock model for the tutor agent
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0

# Agent server port
AGENT_PORT=8000

# Next.js points here to reach the agent
AGENT_URL=http://localhost:8000
